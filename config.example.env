# example-agent — principal overlay config (EXAMPLE)
#
# Copy this to ~/.config/metafactory/example-agent/.env and edit. It is read at
# brain startup (brain/env.ts) and lets YOU — the installing principal — choose
# your agent's identity WITHOUT editing the installed pack, so `arc upgrade` and
# clean reinstalls never overwrite your choices.

# The ASSISTANT NAME — the named being this agent hosts. Greetings use it, so two
# principals who both install this pack run e.g. "Aria" and "Pylon", not two
# clones. Per cortex's ubiquitous language: the name is config, never contract.
EXAMPLE_AGENT_DISPLAY_NAME="Aria"

# Optional: point at your own persona file. Resolution order (first hit wins):
#   1. this path (EXAMPLE_AGENT_PERSONA)
#   2. ~/.config/metafactory/example-agent/persona.md   (drop a file here)
#   3. the pack's shipped persona.md                    (default)
# EXAMPLE_AGENT_PERSONA="/Users/you/.config/metafactory/example-agent/persona.md"
